# MongoDB connection string
MONGODB_URI=

# Treasury wallet — receives pool entry fees
NEXT_PUBLIC_TREASURY_WALLET=

# Treasury private key — used server-side to send SOL payouts to winners
# Export from Phantom: Settings → Security → Export Private Key (base58 string)
# KEEP THIS SECRET — only add to Vercel env vars, never commit to git
TREASURY_PRIVATE_KEY=

# Bags API Key
NEXT_PUBLIC_BAGS_API_KEY=
NEXT_PUBLIC_BAGS_PARTNER_KEY=

# Solana RPC — FREE: sign up at https://helius.dev and paste your RPC URL
# The public mainnet RPC blocks most requests. You MUST use Helius or similar.
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
